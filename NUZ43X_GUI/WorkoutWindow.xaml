<Window x:Class="NUZ43X_GUI.WorkoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NUZ43X_GUI"
        mc:Ignorable="d"
        Title="WorkoutWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Dátum:"/>
        <DatePicker Grid.Row="0"
                    Margin="80,0,0,10"
                    SelectedDate="{Binding Date}"/>

        <TextBlock Grid.Row="1" Text="Cím:"/>
        <TextBox Grid.Row="1"
                 Margin="80,0,0,10"
                 Text="{Binding Title}"/>

        <TextBlock Grid.Row="2" Text="Gyakorlat:"/>
        <ComboBox x:Name="ExerciseComboBox"
                  Grid.Row="2"
                  Margin="80,0,0,10"
                  DisplayMemberPath="Name"/>

        <Button Grid.Row="3"
                Content="Hozzáadás"
                Width="120"
                Height="30"
                HorizontalAlignment="Left"
                Click="AddExercise_Click"/>

        <ListBox Grid.Row="3"
                 Margin="140,0,0,0"
                 ItemsSource="{Binding Entries}"
                 DisplayMemberPath="ExerciseName"/>

        <Button Grid.Row="4"
                Content="Mentés"
                Width="120"
                HorizontalAlignment="Right"
                Click="Save_Click"/>
    </Grid>
</Window>
