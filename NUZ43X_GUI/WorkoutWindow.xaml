<Window x:Class="NUZ43X_GUI.WorkoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NUZ43X_GUI"
        mc:Ignorable="d"
        Title="WorkoutWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Text="Dátum:"/>
        <DatePicker Grid.Row="0"
                    Grid.Column="1"
                    Margin="0,0,10,10"
                    SelectedDate="{Binding Date}"/>

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Text="Cím:"/>
        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Grid.ColumnSpan="3"
                 Margin="0,0,0,10"
                 Text="{Binding Title}"/>

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Text="Gyakorlat:"/>
        <ComboBox x:Name="ExerciseComboBox"
                  Grid.Row="2"
                  Grid.Column="1"
                  Margin="0,0,10,10"
                  DisplayMemberPath="Name"/>

        <TextBlock Grid.Row="2"
                   Grid.Column="2"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Text="Súly:"/>
        <TextBox x:Name="WeightTextBox"
                 Grid.Row="2"
                 Grid.Column="3"
                 Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3"
                   Grid.Column="2"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Text="Ismétlés:"/>
        <TextBox x:Name="RepetitionsTextBox"
                 Grid.Row="3"
                 Grid.Column="3"
                 Margin="0,0,0,10"/>

        <Button Grid.Row="3"
                Grid.Column="1"
                Width="140"
                Height="30"
                HorizontalAlignment="Left"
                Content="Sorozat hozzáadása"
                Click="AddSet_Click"/>

        <DataGrid x:Name="WorkoutEntriesDataGrid"
          Grid.Row="4"
          Grid.Column="0"
          Grid.ColumnSpan="4"
          AutoGenerateColumns="False"
          Margin="0,15,0,15"
          IsReadOnly="True"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          ItemsSource="{Binding Entries}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Gyakorlat" Binding="{Binding ExerciseName}" Width="2*"/>
                <DataGridTextColumn Header="Sorozatok száma" Binding="{Binding Sets.Count}" Width="*"/>
                <DataGridTextColumn Header="Sorozatok" Binding="{Binding SetSummary}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="5"
                Grid.Column="3"
                Width="120"
                HorizontalAlignment="Right"
                Content="Mentés"
                Click="Save_Click"/>
    </Grid>
</Window>
