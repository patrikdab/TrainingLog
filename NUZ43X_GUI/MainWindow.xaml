<Window x:Class="NUZ43X_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edzésnapló"
        Height="800"
        Width="950"
        WindowStartupLocation="CenterScreen"
        FontSize="14">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15" Orientation="Vertical">

            <GroupBox Header="Gyakorlatok" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <DataGrid x:Name="ExercisesDataGrid"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding Exercises}"
                              Height="200"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Kategória" Binding="{Binding Category}" Width="2*"/>
                            <DataGridTextColumn Header="Leírás" Binding="{Binding Description}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Új gyakorlat"
                                Width="120"
                                Margin="0,0,10,0"
                                Click="AddExerciseButton_Click"/>
                        <Button Content="Szerkesztés"
                                Width="120"
                                Margin="0,0,10,0"
                                Click="EditExerciseButton_Click"/>
                        <Button Content="Törlés"
                                Width="120"
                                Click="DeleteExerciseButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Edzések" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <DataGrid x:Name="WorkoutsDataGrid"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding Workouts}"
                              Height="200"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dátum"
                                                Binding="{Binding Date, StringFormat=d}"
                                                Width="2*"/>
                            <DataGridTextColumn Header="Cím"
                                                Binding="{Binding Title}"
                                                Width="3*"/>
                            <DataGridTextColumn Header="Gyakorlatok száma"
                                                Binding="{Binding Entries.Count}"
                                                Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Új edzés"
                                Width="120"
                                Click="AddWorkout_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Testsúlyok" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <DataGrid x:Name="BodyWeightsDataGrid"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding BodyWeights}"
                              Height="200"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dátum"
                                                Binding="{Binding Date, StringFormat=d}"
                                                Width="2*"/>
                            <DataGridTextColumn Header="Testsúly (kg)"
                                                Binding="{Binding Weight}"
                                                Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Content="Új testsúly"
                                Width="120"
                                Click="AddBodyWeightButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,10,0,0">
                <Button Content="Statisztika"
            Width="120"
            Margin="0,0,10,0"
            Click="OpenStatisticsButton_Click"/>
                <Button Content="Új edzés"
            Width="120"
            Click="AddWorkout_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>